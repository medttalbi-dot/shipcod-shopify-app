# Shopify App credentials (from Shopify Partners dashboard)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Your deployed app URL (no trailing slash)
SHOPIFY_APP_URL=https://your-app-domain.com

# Database
# SQLite for local dev:
DATABASE_URL="file:./dev.db"
# PostgreSQL for production:
# DATABASE_URL="postgresql://user:password@host:5432/shipcod_shopify?schema=public"

# AES-256-GCM encryption key for SECRET_CODE at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_encryption_key

# Shopify scopes (must match shopify.app.toml)
SCOPES=read_orders,write_orders
